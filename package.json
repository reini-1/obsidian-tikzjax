{
    "name": "obsidian-tikzjax",
    "version": "0.6.0",
    "description": "Render LaTeX and TikZ diagrams in your notes",
    "main": "main.js",
    "type": "module",
    "scripts": {
        "clean": "rm -rf build",
        "prebuild": "node update-tikzjax.mjs",
        "build": "npm run clean && npm run prebuild && npx tsc -noEmit -skipLibCheck && node esbuild.config.mjs production && npm run copy-files",
        "dev": "node esbuild.config.mjs watch",
        "copy-files": "node copy-files.mjs",
        "rebuild": "npm run clean && npm run build",
        "update-tikzjax": "node update-tikzjax.mjs",
        "version": "node version-bump.mjs && git add manifest.json versions.json"
    },
    "keywords": [],
    "author": "",
    "license": "MIT",
    "devDependencies": {
        "@types/localforage": "^0.0.33",
        "@types/node": "^22.10.2",
        "@typescript-eslint/eslint-plugin": "^8.18.1",
        "@typescript-eslint/parser": "^8.18.1",
        "builtin-modules": "^4.0.0",
        "esbuild": "^0.28.1",
        "eslint": "^9.17.0",
        "obsidian": "latest",
        "tslib": "^2.8.1",
        "typescript": "^5.7.2"
    },
    "allowScripts": {
        "esbuild@0.28.1": true
    },
    "dependencies": {
        "localforage": "^1.10.0"
    }
}
